{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "preserve",
    "jsxImportSource": "solid-js",

    "types": ["vite/client"],

    "strict": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/solid/*"]
    },

    "skipLibCheck": true
  }
}
